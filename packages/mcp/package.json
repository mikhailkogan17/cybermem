{
  "name": "@cybermem/mcp",
  "version": "0.15.0",
  "description": "CyberMem MCP Server - AI Memory with openmemory-js SDK",
  "main": "dist/index.js",
  "bin": {
    "cybermem-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "node scripts/postbuild.js",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test",
    "inspect": "mcp-inspector npx ts-node src/index.ts",
    "inspect:built": "mcp-inspector node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mikhailkogan17/cybermem.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://cybermem.dev",
  "bugs": {
    "url": "https://github.com/mikhailkogan17/cybermem/issues"
  },
  "keywords": [
    "mcp",
    "ai-memory",
    "claude",
    "cursor",
    "openmemory",
    "llm"
  ],
  "author": "Mikhail Kogan <mikhailkogan17@gmail.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "fastmcp": "^3.33.0",
    "openmemory-js": "1.3.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.19.0",
    "@playwright/test": "^1.57.0",
    "@types/node": "^18.0.0",
    "eventsource": "^4.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
