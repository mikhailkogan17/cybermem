{
  "name": "cybermem-mcp",
  "version": "0.2.0",
  "description": "CyberMem Management CLI",
  "bin": {
    "cybermem": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc && cp -r templates dist/",
    "start": "ts-node src/index.ts",
    "test:e2e": "ts-node e2e/test-mcp.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cybermem",
    "cli",
    "ai",
    "mcp"
  ],
  "author": "Mikhail Kogan",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.0.0",
    "dotenv": "^16.0.0",
    "execa": "^5.1.1",
    "inquirer": "^8.2.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.3",
    "@types/node": "^18.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
