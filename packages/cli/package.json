{
  "name": "@cybermem/cli",
  "version": "0.12.5",
  "description": "CyberMem — Universal Long-Term Memory for AI Agents",
  "homepage": "https://cybermem.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikhailkogan17/cybermem.git",
    "directory": "packages/cli"
  },
  "bin": {
    "cybermem-cli": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "mkdir -p dist && tsc && cp -r templates dist/",
    "lint": "eslint src/ --ext .ts",
    "start": "ts-node src/index.ts",
    "test:e2e": "ts-node e2e/test-mcp.ts",
    "prepublishOnly": "npm run build && ts-node ../../scripts/verify-release-report.ts"
  },
  "keywords": [
    "cybermem",
    "cli",
    "ai",
    "mcp"
  ],
  "author": "Mikhail Kogan",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "commonjs",
  "dependencies": {
    "@types/open": "^6.1.0",
    "chalk": "^4.1.2",
    "commander": "^9.0.0",
    "dotenv": "^16.0.0",
    "execa": "^5.1.1",
    "inquirer": "^8.2.0",
    "open": "^11.0.0",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.3",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0"
  }
}
