{
  "name": "cybermem",
  "private": true,
  "description": "Unified AI Memory System",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@playwright/test": "^1.57.0"
  },
  "scripts": {
    "prepare": "bash scripts/setup-hooks.sh",
    "build": "npm run build --workspaces --if-present",
    "test:unit": "jest",
    "test:e2e": "playwright test",
    "test:e2e:ci": "playwright test",
    "cli": "npm run start -w packages/cli",
    "dashboard:dev": "npm run dev -w packages/dashboard",
    "mcp:dev": "npm run dev -w packages/mcp",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "axios": "^1.13.4",
    "commander": "^14.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.8.0",
    "openmemory-js": "^1.3.2"
  },
  "version": "0.14.10"
}
