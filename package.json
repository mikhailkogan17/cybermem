{
  "name": "cybermem",
  "private": true,
  "description": "Unified AI Memory System",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "@playwright/test": "^1.57.0"
  },
  "scripts": {
    "prepare": "bash scripts/setup-hooks.sh",
    "build": "npm run build --workspaces --if-present",
    "test:unit": "jest",
    "test:e2e": "npx ts-node packages/cli/e2e/e2e.ts",
    "test:e2e:ci": "npx ts-node packages/cli/e2e/e2e.ts --only-testing localhost-prod",
    "cli": "npm run start -w @cybermem/cli",
    "dashboard:dev": "npm run dev -w @cybermem/dashboard",
    "mcp:dev": "npm run dev -w @cybermem/mcp",
    "release": "./tools/release.sh"
  },
  "devDependencies": {
    "axios": "^1.13.4",
    "commander": "^14.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^13.8.0",
    "openmemory-js": "^1.3.2"
  },
  "version": "0.13.0"
}
