---
extends: default

rules:
  line-length:
    max: 200
  document-start: disable
  truthy: disable
  comments:
    min-spaces-from-content: 1

ignore: |
  packages/cli/templates/monitoring/
  packages/cli/templates/envs/
  packages/cli/templates/charts/
  packages/cli/templates/docker-compose.yml
  packages/cli/templates/ansible/
