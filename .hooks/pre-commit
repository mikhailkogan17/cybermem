#!/bin/bash
# 💀 [СМЕРТЕЛЬНЫЙ ЗАПРЕТ] — ГЕЙТКИПЕР НЕ ДОЛЖЕН МЕНЯТЬСЯ БЕЗ ЯВНОГО СОГЛАСИЯ ЮЗЕРА!
# 💀 [LETHAL PROHIBITION] — DO NOT MODIFY GATEKEEPER WITHOUT EXPLICIT USER CONSENT!

# CyberMem GATEKEEPER — Regression Report Checker
# Source of Truth: .hooks/pre-commit

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  🔒 CyberMem GATEKEEPER — Regression Checker                  "
echo "═══════════════════════════════════════════════════════════════"
echo ""

# Find current version from Root SSoT
if [ -f "package.json" ]; then
    VERSION=$(grep '"version"' package.json | head -1 | cut -d'"' -f4)
    REPORT_FILE="release-reports/release-report-$VERSION.md"
else
    echo -e "${RED}❌ FAILED: Missing root package.json${NC}"
    exit 1
fi

echo "📦 Target Version: v$VERSION"
echo "📄 Checking Report: $REPORT_FILE"

if [ ! -f "$REPORT_FILE" ]; then
    echo -e "${RED}❌ FAILED: Release report $REPORT_FILE does not exist!${NC}"
    echo "    Run full regression and create the report from TEMPLATE.md."
    exit 1
fi

# Validation logic
FAILED=0

check_field() {
    local pattern="$1"
    local description="$2"
    if ! grep -q "$pattern" "$REPORT_FILE"; then
        echo -e "${RED}❌ MISSING: $description${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✅ FOUND: $description${NC}"
    fi
}

check_checked() {
    local pattern="$1"
    local description="$2"
    # Check if the line exists AND is checked
    if grep -q "$pattern" "$REPORT_FILE"; then
        if grep "$pattern" "$REPORT_FILE" | grep -q '\[x\]'; then
            echo -e "${GREEN}✅ VERIFIED: $description${NC}"
        else
            echo -e "${RED}❌ UNCHECKED: $description (must be [x])${NC}"
            FAILED=1
        fi
    else
        echo -e "${RED}❌ MISSING: $description${NC}"
        FAILED=1
    fi
}

echo "--- Template Integrity ---"
TEMPLATE_FILE="release-reports/TEMPLATE.md"
if [ -f "$TEMPLATE_FILE" ]; then
    # Extract headers (## and ###) from template to ensure they exist in report
    grep -E "^##?#? " "$TEMPLATE_FILE" | while read -r header; do
        # Escape for grep
        clean_header=$(echo "$header" | sed 's/\[Version\]/.*/g' | sed 's/\[.*\]/.*/g' | sed 's/(.*)//g' | xargs)
        if ! grep -q "$clean_header" "$REPORT_FILE"; then
            echo -e "${RED}❌ MISSING SECTION: Header similar to '$header' must exist in report.${NC}"
            FAILED=1
        else
            echo -e "${GREEN}✅ FOUND SECTION: $header${NC}"
        fi
    done
else
    echo -e "${YELLOW}⚠️ WARN: TEMPLATE.md not found, skipping dynamic comparison.${NC}"
fi

echo ""
echo "--- Asset Validation ---"
# Check if all referenced images exist
grep -oE "!\[.*\]\((.*)\)" "$REPORT_FILE" | sed -E "s/!\[.*\]\((.*)\)/\1/" | while read -r asset; do
    # Handle relative paths
    asset_path="release-reports/$asset"
    if [ ! -f "$asset_path" ]; then
        # Check if it's already an absolute path or relative to project root
        if [ ! -f "$asset" ]; then
            echo -e "${RED}❌ MISSING ASSET: $asset (referenced in report)${NC}"
            FAILED=1
        else
            echo -e "${GREEN}✅ FOUND ASSET: $asset${NC}"
        fi
    else
        echo -e "${GREEN}✅ FOUND ASSET: $asset${NC}"
    fi
done

echo ""
echo "--- Content Validation ---"
echo "--- Checkbox Validation ---"
# Check for concrete Identity Law in Staging
check_checked "Identity Law.*CONCRETE APP" "Identity Law"
check_checked "Audit Logs.*Full CRUD.*verified" "Audit Log CRUD"
check_checked "Audit Logs.*Zero errors detected" "Audit Log Integrity"

# Check for Migration and Port Isolation
check_checked "Migration.*test passed" "Migration Test"
check_checked "Port Isolation.*dashboard ports" "Port Isolation Check"

# Check for Zero Trust Statement (confirm text has [x])
check_checked "I hereby confirm that E2E tests have passed" "Zero Trust Statement"

# Final block check: any unchecked items at all in non-failed sections?
# We use awk to only check for [ ] in sections that are NOT failed/skipped
CHECKBOXES=$(awk '
  /^## / { in_failed=0 }
  /\*\*Status\*\*:[[:space:]]*(❌|⏭️)/ { in_failed=1 }
  /\[ \]/ { if (!in_failed) print NR ":" $0 }
' "$REPORT_FILE")

if [ -n "$CHECKBOXES" ]; then
    echo -e "${RED}❌ FAILED: There are still empty checkboxes [ ] in active (non-failed) sections!${NC}"
    echo "$CHECKBOXES"
    FAILED=1
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"

echo ""
echo "--- CLI Spec Validation ---"
# Verify CLI commands exist and report help correctly
echo "🔍 Checking 'cybermem-cli' spec..."
# We use npx to run the local version if not installed globally
# Assuming the package is linked or we can run from source
CLI_BIN="npx ts-node packages/cli/src/index.ts"

check_cli_cmd() {
    local cmd="$1"
    if $CLI_BIN "$cmd" --help | grep -q "$cmd"; then
        echo -e "${GREEN}✅ SPEC PASSED: $cmd reports help${NC}"
    else
        echo -e "${RED}❌ SPEC FAILED: $cmd help verification failed${NC}"
        FAILED=1
    fi
}

check_cli_cmd "install"
check_cli_cmd "uninstall"
check_cli_cmd "upgrade"

echo ""
echo "--- Infrastructure Linting ---"
# Placeholder for linters - will be expanded
if command -v ansible-lint &> /dev/null; then
    echo "🔍 Running ansible-lint..."
    ansible-lint packages/cli/templates/ansible/
else
    echo -e "${YELLOW}⚠️ WARN: ansible-lint not found, skipping${NC}"
fi

if command -v yamllint &> /dev/null; then
    echo "🔍 Running yamllint..."
    yamllint packages/cli/templates/
else
    echo -e "${YELLOW}⚠️ WARN: yamllint not found, skipping${NC}"
fi

if command -v helm &> /dev/null; then
    echo "🔍 Running helm lint..."
    helm lint packages/cli/templates/charts/cybermem
else
    echo -e "${YELLOW}⚠️ WARN: helm not found, skipping${NC}"
fi

# pre-commit hook updates
echo ""
echo "🔍 Checking Hook Integrity..."

# 1. Check if the tracked hook itself has uncommitted changes
if ! git diff --quiet HEAD -- .hooks/pre-commit; then
    echo -e "${RED}❌ FAILED: .hooks/pre-commit has been modified but not committed!${NC}"
    echo -e "${YELLOW}⚠️  INSTRUCTION: CHANGING TESTS UPON REPORT FAILURE IS FORBIDDEN.${NC}"
    echo -e "${YELLOW}    ONLY ALLOWED ACTION: FIX THE SOURCE CAUSE OR REQUEST FORCE PUSH FROM USER.${NC}"
    FAILED=1
else
    echo -e "${GREEN}✅ VERIFIED: Tracked hook is clean${NC}"
fi

# 2. Check if the active git hook is actually pointing to our tracked hooks
# Or at least check that they are identical
if [ -f ".git/hooks/pre-commit" ] && ! diff -q .hooks/pre-commit .git/hooks/pre-commit > /dev/null; then
    echo -e "${RED}❌ FAILED: Active hook (.git/hooks/pre-commit) does not match tracked hook (.hooks/pre-commit)!${NC}"
    echo "    Run: cp .hooks/pre-commit .git/hooks/pre-commit"
    FAILED=1
else
    echo -e "${GREEN}✅ VERIFIED: Active hook matches source of truth${NC}"
fi

if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}  ❌ GATEKEEPER BLOCKED — Resolve hook conflicts or report first  ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 1
else
    echo -e "${GREEN}  ✅ GATEKEEPER PASSED — System Integrity Verified            ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 0
fi
