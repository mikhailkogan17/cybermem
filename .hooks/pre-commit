#!/bin/bash
# FOR ALL CODE_AGENTS: ЗАПРЕЩЕНО СКИПАТЬ БЕЗ ЯВНОГО РАЗРЕШЕНИЯ ЮЗЕРА
# FOR ALL CODE_AGENTS: ЗАПРЕЩЕНО СКИПАТЬ БЕЗ ЯВНОГО РАЗРЕШЕНИЯ ЮЗЕРА

# CyberMem GATEKEEPER — Regression Report Checker
# Shifted from runner to validator for v0.9.13+

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  🔒 CyberMem GATEKEEPER — Regression Checker                  "
echo "═══════════════════════════════════════════════════════════════"
echo ""

# Find current version from Root SSoT
if [ -f "package.json" ]; then
    VERSION=$(grep '"version"' package.json | head -1 | cut -d'"' -f4)
    REPORT_FILE="release-reports/release-report-$VERSION.md"
else
    echo -e "${RED}❌ FAILED: Missing root package.json${NC}"
    exit 1
fi

echo "📦 Target Version: v$VERSION"
echo "📄 Checking Report: $REPORT_FILE"

if [ ! -f "$REPORT_FILE" ]; then
    echo -e "${RED}❌ FAILED: Release report $REPORT_FILE does not exist!${NC}"
    echo "    Run full regression and create the report from TEMPLATE.md."
    exit 1
fi

# Validation logic
FAILED=0

check_field() {
    local pattern="$1"
    local description="$2"
    if ! grep -q "$pattern" "$REPORT_FILE"; then
        echo -e "${RED}❌ MISSING: $description${NC}"
        FAILED=1
    else
        echo -e "${GREEN}✅ FOUND: $description${NC}"
    fi
}

check_checked() {
    local pattern="$1"
    local description="$2"
    # Check if the line exists AND is checked
    if grep -q "$pattern" "$REPORT_FILE"; then
        if grep "$pattern" "$REPORT_FILE" | grep -q '\[x\]'; then
            echo -e "${GREEN}✅ VERIFIED: $description${NC}"
        else
            echo -e "${RED}❌ UNCHECKED: $description (must be [x])${NC}"
            FAILED=1
        fi
    else
        echo -e "${RED}❌ MISSING: $description${NC}"
        FAILED=1
    fi
}

echo "--- Content Validation ---"
check_field "Локально собрано?" "Build Status"
check_field "Версия компонентов локально" "Local Versions"
check_field "Ответ на /stats" "Stats Verification"
check_field "Add Memory" "CRUD: Add"
check_field "Query Memory" "CRUD: Query"
check_field "Update Memory" "CRUD: Update"
check_field "Delete Memory" "CRUD: Delete"

echo ""
echo "--- Checkbox Validation ---"
check_checked "Локально собрано?" "Build Confirmation"
check_checked "Версия компонентов локально" "Version Confirmation"
check_checked "Ответ на /stats" "Stats Confirmation"
check_checked "Add Memory" "CRUD: Add"
check_checked "Query Memory" "CRUD: Query"
check_checked "Update Memory" "CRUD: Update"
check_checked "Delete Memory" "CRUD: Delete"
check_checked "GEMINI.md Update" "Identity & Postmortems Verified"

# Final block check: any unchecked items at all?
if grep -q '\[ \]' "$REPORT_FILE"; then
    echo -e "${RED}❌ FAILED: There are still empty checkboxes [ ] in the report!${NC}"
    grep -n '\[ \]' "$REPORT_FILE"
    FAILED=1
fi

echo ""
echo "═══════════════════════════════════════════════════════════════"

if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}  ❌ GATEKEEPER BLOCKED — Complete the Release Report first  ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 1
else
    echo -e "${GREEN}  ✅ GATEKEEPER PASSED — Regression documented            ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 0
fi
