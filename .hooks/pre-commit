#!/bin/bash
# CyberMem LITE PRE-COMMIT — Linters Only

set -e
export PATH="$PATH:/opt/homebrew/bin:/usr/local/bin"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo ""
echo "═══════════════════════════════════════════════════════════════"
echo "  🧹 CyberMem — Pre-Commit                           "
echo "═══════════════════════════════════════════════════════════════"
echo ""

FAILED=0

# 1. Code Linting (ESLint, etc.)
echo "🔍 Running code linters..."
if npm run lint --workspaces --if-present; then
    echo -e "${GREEN}✅ Code linting passed${NC}"
else
    echo -e "${RED}❌ Code linting failed${NC}"
    FAILED=1
fi

echo ""
echo "--- Infrastructure Linting ---"

# 2. Infra Linters
if command -v ansible-lint &> /dev/null; then
    echo "🔍 Running ansible-lint..."
    if ansible-lint packages/cli/templates/ansible/; then
         echo -e "${GREEN}✅ Ansible lint passed${NC}"
    else
         echo -e "${RED}❌ Ansible lint failed${NC}"
         FAILED=1
    fi
else
    echo -e "${YELLOW}⚠️ WARN: ansible-lint not found, skipping${NC}"
fi

if command -v yamllint &> /dev/null; then
    echo "🔍 Running yamllint..."
    if yamllint packages/cli/templates/; then
        echo -e "${GREEN}✅ YAML lint passed${NC}"
    else
        echo -e "${RED}❌ YAML lint failed${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}⚠️ WARN: yamllint not found, skipping${NC}"
fi

if command -v helm &> /dev/null; then
    echo "🔍 Running helm lint..."
    if helm lint packages/cli/templates/charts/cybermem; then
        echo -e "${GREEN}✅ Helm lint passed${NC}"
    else
        echo -e "${RED}❌ Helm lint failed${NC}"
        FAILED=1
    fi
else
    echo -e "${YELLOW}⚠️ WARN: helm not found, skipping${NC}"
fi

if [ "$FAILED" -eq 1 ]; then
    echo -e "${RED}  ❌ LINTING FAILED — Fix code style/syntax errors            ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 1
else
    echo -e "${GREEN}  ✅ LINTING PASSED — Ready to commit                         ${NC}"
    echo "═══════════════════════════════════════════════════════════════"
    exit 0
fi
